{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "State by Style Matrix",
    "subtitle": "Concentration of top beers across states",
    "font": "Oswald",
    "fontSize": 20,
    "subtitleFont": "Montserrat",
    "subtitleColor": "#64748B"
  },
  "data": {
    "url": "../gabs_hottest_100_2025.json"
  },
  "transform": [
    {
      "aggregate": [{"op": "count", "as": "BeerCount"}],
      "groupby": ["state_name", "style"]
    }
  ],
  "mark": {"type": "rect", "tooltip": true, "cornerRadius": 2},
  "encoding": {
    "x": {
      "field": "state_name",
      "type": "nominal",
      "axis": {"labelFont": "Montserrat", "title": null, "labelAngle": 0}
    },
    "y": {
      "field": "style",
      "type": "nominal",
      "axis": {"labelFont": "Montserrat", "title": null, "labelLimit": 200}
    },
    "color": {
      "field": "BeerCount",
      "type": "quantitative",
      "scale": {"scheme": "yelloworangebrown"},
      "legend": {"title": "Top 100 Entries", "labelFont": "Montserrat", "orient": "right", "titleFont": "Montserrat"}
    },
    "tooltip": [
      {"field": "state_name", "type": "nominal", "title": "State"},
      {"field": "style", "type": "nominal", "title": "Style"},
      {"field": "BeerCount", "type": "quantitative", "title": "Number of Beers"}
    ]
  },
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Montserrat"
  }
}
