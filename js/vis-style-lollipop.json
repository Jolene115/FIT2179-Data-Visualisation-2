{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 300,
  "title": {
    "text": "The Anatomy of the Top 100",
    "subtitle": "Most popular beer styles by volume",
    "font": "Oswald",
    "fontSize": 20,
    "subtitleFont": "Montserrat",
    "subtitleColor": "#64748B"
  },
  "data": {"url": "gabs_hottest_100_2025.json"},
  "transform": [
    {
      "aggregate": [{"op": "count", "as": "Count"}],
      "groupby": ["style"]
    },
    {
      "window": [{"op": "rank", "as": "rank"}],
      "sort": [{"field": "Count", "order": "descending"}]
    },
    {"filter": "datum.rank <= 8"}
  ],
  "encoding": {
    "y": {
      "field": "style",
      "type": "nominal",
      "sort": {"field": "Count", "order": "descending"},
      "axis": null
    },
    "x": {
      "field": "Count",
      "type": "quantitative",
      "axis": null
    }
  },
  "layer": [
    {
      "mark": {"type": "bar", "cornerRadiusEnd": 4, "height": {"band": 0.8}},
      "encoding": {
        "color": {
          "field": "Count",
          "type": "quantitative",
          "scale": {"range": ["#FDE68A", "#B45309"]},
          "legend": null
        }
      }
    },
    {
      "mark": {"type": "text", "align": "left", "dx": 5, "font": "Oswald", "fontSize": 14, "color": "#111"},
      "encoding": {
        "x": {"datum": 0},
        "text": {"field": "style", "type": "nominal"}
      }
    },
    {
      "mark": {"type": "text", "align": "right", "dx": -5, "font": "Montserrat", "fontWeight": "bold", "color": "#fff"},
      "encoding": {
        "x": {"field": "Count"},
        "text": {"field": "Count", "type": "quantitative"}
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Montserrat"
  }
}
