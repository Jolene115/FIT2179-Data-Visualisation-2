{
  "$schema": "https://vega.github.io/schema/vega-lite/v5.json",
  "width": "container",
  "height": 400,
  "title": {
    "text": "Rank Density by Style",
    "subtitle": "Mapping the exact placement of every beer",
    "font": "Oswald",
    "fontSize": 20,
    "subtitleFont": "Montserrat",
    "subtitleColor": "#64748B"
  },
  "data": {"url": "../gabs_hottest_100_2025.json"},
  "transform": [
    {
      "joinaggregate": [{"op": "count", "as": "StyleCount"}],
      "groupby": ["style"]
    },
    {
      "joinaggregate": [{"op": "median", "field": "rank", "as": "MedianRank"}],
      "groupby": ["style"]
    },
    {"filter": "datum.StyleCount >= 4"},
    {
      "calculate": "random()", "as": "jitter"
    }
  ],
  "encoding": {
    "y": {
      "field": "style",
      "type": "nominal",
      "sort": {"field": "MedianRank", "op": "min"},
      "axis": {"labelFont": "Montserrat", "title": null, "labelLimit": 150}
    },
    "x": {
      "field": "rank",
      "type": "quantitative",
      "title": "GABS Rank (1 is Best)",
      "axis": {"labelFont": "Montserrat", "titleFont": "Montserrat"}
    }
  },
  "layer": [
    {
      "mark": {
        "type": "circle",
        "size": 100,
        "opacity": 0.8,
        "stroke": "#111",
        "strokeWidth": 0.5
      },
      "encoding": {
        "yOffset": {"field": "jitter", "type": "quantitative", "scale": {"range": [-10, 10]}},
        "color": {
          "field": "rank",
          "type": "quantitative",
          "scale": {"range": ["#B45309", "#FDE68A"]},
          "legend": null
        },
        "tooltip": [
          {"field": "beer", "type": "nominal", "title": "Beer"},
          {"field": "brewery", "type": "nominal", "title": "Brewery"},
          {"field": "style", "type": "nominal", "title": "Style"},
          {"field": "MedianRank", "type": "quantitative", "format": ".1f", "title": "Style median rank"},
          {"field": "rank", "type": "quantitative", "title": "Rank"}
        ]
      }
    },
    {
      "transform": [{"filter": "datum.rank == 1"}],
      "mark": {
        "type": "text",
        "align": "left",
        "dx": 10,
        "dy": -15,
        "font": "Oswald",
        "fontSize": 14,
        "color": "#B45309"
      },
      "encoding": {
        "text": {"value": "← #1: Status Quo (Hazy Pale)"}
      }
    },
    {
      "transform": [
        {
          "aggregate": [
            {"op": "median", "field": "rank", "as": "MedianRank"},
            {"op": "count", "as": "StyleCount"}
          ],
          "groupby": ["style"]
        },
        {"filter": "datum.StyleCount >= 4"}
      ],
      "mark": {
        "type": "tick",
        "color": "#111111",
        "thickness": 3,
        "size": 28
      },
      "encoding": {
        "x": {"field": "MedianRank", "type": "quantitative"},
        "tooltip": [
          {"field": "style", "type": "nominal", "title": "Style"},
          {"field": "MedianRank", "type": "quantitative", "format": ".1f", "title": "Median rank"}
        ]
      }
    },
    {
      "mark": {
        "type": "text",
        "align": "left",
        "baseline": "bottom",
        "dx": 5,
        "dy": -176,
        "font": "Montserrat",
        "color": "#111111",
        "fontSize": 12
      },
      "encoding": {
        "x": {"datum": 42},
        "y": null,
        "text": {"value": "Black ticks show each style's median rank"}
      }
    }
  ],
  "config": {
    "view": {"stroke": "transparent"},
    "font": "Montserrat"
  }
}
